# Firebase web config — copied from Firebase console → Project settings → Your apps
# Safe to commit values are NOT secrets, but we still keep them out of git so each
# environment can have its own. The actual values live in .env.local (gitignored).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional — only set if you've configured a custom domain in Firebase Hosting.
# Used to build "Copy tracking link" URLs. Defaults to window.location.origin
# at runtime if not set.
VITE_PUBLIC_BASE_URL=
